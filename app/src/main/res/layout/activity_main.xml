<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:paddingHorizontal="24dp"
        android:paddingVertical="28dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/app_name"
            android:textColor="@color/on_bg"
            android:textSize="18sp"
            android:textStyle="bold"
            android:letterSpacing="0.02" />

        <!-- Big time / remaining -->
        <TextView
            android:id="@+id/bigTime"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="30"
            android:textColor="@color/accent"
            android:textSize="76sp"
            android:textStyle="bold"
            android:includeFontPadding="false" />

        <TextView
            android:id="@+id/minutesLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/minutes"
            android:textColor="@color/on_bg_dim"
            android:textSize="16sp" />

        <!-- Duration slider -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:text="@string/duration_heading"
            android:textAllCaps="true"
            android:textColor="@color/on_bg_dim"
            android:textSize="12sp"
            android:letterSpacing="0.08" />

        <SeekBar
            android:id="@+id/seekMinutes"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp" />

        <!-- Presets -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="@string/presets_heading"
            android:textAllCaps="true"
            android:textColor="@color/on_bg_dim"
            android:textSize="12sp"
            android:letterSpacing="0.08" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:orientation="horizontal"
            android:baselineAligned="false">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/preset15"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="4dp"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:paddingHorizontal="0dp"
                android:minWidth="0dp"
                android:text="15" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/preset30"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginHorizontal="4dp"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:paddingHorizontal="0dp"
                android:minWidth="0dp"
                android:text="30" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/preset45"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginHorizontal="4dp"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:paddingHorizontal="0dp"
                android:minWidth="0dp"
                android:text="45" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/preset60"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginHorizontal="4dp"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:paddingHorizontal="0dp"
                android:minWidth="0dp"
                android:text="60" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/preset90"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="4dp"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:paddingHorizontal="0dp"
                android:minWidth="0dp"
                android:text="90" />
        </LinearLayout>

        <!-- Fade-out length -->
        <TextView
            android:id="@+id/fadeLabel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="@string/fade_label"
            android:textAllCaps="true"
            android:textColor="@color/on_bg_dim"
            android:textSize="12sp"
            android:letterSpacing="0.08" />

        <SeekBar
            android:id="@+id/seekFade"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp" />

        <!-- Screen-off mode -->
        <com.google.android.material.materialswitch.MaterialSwitch
            android:id="@+id/switchScreenOff"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:minHeight="48dp"
            android:text="@string/screen_off_label"
            android:textColor="@color/on_bg"
            android:textSize="15sp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:text="@string/screen_off_hint"
            android:textColor="@color/on_bg_dim"
            android:textSize="12sp" />

        <!-- Start / Stop -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/startStop"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:paddingVertical="14dp"
            android:text="@string/start"
            android:textSize="16sp"
            android:textStyle="bold"
            app:cornerRadius="16dp" />

        <TextView
            android:id="@+id/status"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:gravity="center"
            android:text="@string/status_idle"
            android:textColor="@color/on_bg_dim"
            android:textSize="13sp" />

        <TextView
            android:id="@+id/credit"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:gravity="center"
            android:padding="8dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:clickable="true"
            android:focusable="true"
            android:text="@string/credit"
            android:textColor="@color/on_bg_dim"
            android:textSize="12sp"
            android:alpha="0.7" />

    </LinearLayout>
</ScrollView>
